# Gmail credentials for contact form
# ─────────────────────────────────────────────────────────
# GMAIL_USER     → your Gmail address that will SEND emails
#                  e.g. yourname@gmail.com
#
# GMAIL_APP_PASSWORD → 16-character App Password from Google
#   How to generate:
#   1. Go to myaccount.google.com
#   2. Security → 2-Step Verification (must be ON)
#   3. Security → App Passwords
#   4. Select app: Mail, device: Other → type "ThinkMindLabs"
#   5. Copy the 16-char password (no spaces) and paste below
# ─────────────────────────────────────────────────────────

GMAIL_USER=yourname@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
